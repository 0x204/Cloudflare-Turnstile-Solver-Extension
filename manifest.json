{
  "manifest_version": 3,
  "name": "Cloudflare Turnstile Solver",
  "version": "1.0",
  "description": "github.com/0x204",
  "permissions": ["debugger", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "logo.png"
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["script.js"],
    "run_at": "document_start"
  }]
}
